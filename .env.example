# Frontend variables exposed by Vite (must start with VITE_)
VITE_APP_ENV=production
VITE_PUBLIC_SITE_URL=https://www.exemplo.com
VITE_API_URL=https://api.exemplo.com
VITE_API_TIMEOUT_MS=15000

# Public integrations and content endpoints
VITE_WHATSAPP_NUMBER=5521999999999
VITE_WHATSAPP_DEFAULT_MESSAGE=Ola%2C%20quero%20falar%20com%20a%20equipe
VITE_VIDEO_BASE_URL=https://cdn.exemplo.com/videos
VITE_CANVAS_ASSETS_BASE_URL=https://cdn.exemplo.com/canvas
VITE_ASSETS_CDN_URL=https://cdn.exemplo.com

# Optional observability/analytics keys that can be public
VITE_SENTRY_DSN=
VITE_ANALYTICS_ID=

# Server-side only variables (do not expose in frontend code)
API_SECRET_KEY=
BACKEND_INTERNAL_TOKEN=
PAYMENT_GATEWAY_SECRET=
